# Facebook auth/session
FB_COOKIES=./cookies.json

# Reply routing
FB_MENTION_ONLY=1
FB_MENTION_NAME=
FB_TRIGGER=bot
FB_ALLOW_THREADS=
FB_OWNER_UID=
FB_AUTO_JOIN=0

# Hermes
HERMES_BIN=hermes
HERMES_PROFILE=fbpublic
HERMES_TOOLSETS=web
HERMES_TIMEOUT=180

# Safety / pacing
FB_MAX_TURNS=30
FB_MAX_AGE_H=6
FB_MAX_REPLY_CHARS=1200
FB_MAX_CHUNKS=2
FB_REPLY_DELAY_MIN=3
FB_REPLY_DELAY_MAX=15
FB_QUIET_START=1
FB_QUIET_END=8
FB_TZ_OFFSET=7

# Optional image/VLM endpoint and reasoning shim
FB_VISION_URL=http://127.0.0.1:1234
SHIM_UPSTREAM=http://127.0.0.1:1234
SHIM_PORT=9877
SHIM_HOST=127.0.0.1
SHIM_HARD_EFFORT=medium
